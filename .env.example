# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Required for production form storage
# Example:
# FIREBASE_PROJECT_ID=nia-events-live
FIREBASE_PROJECT_ID=
# Example:
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@nia-events-live.iam.gserviceaccount.com
FIREBASE_CLIENT_EMAIL=
# Paste the private key as a single line with literal \n characters in Vercel.
# Example:
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nABC123...\n-----END PRIVATE KEY-----\n
FIREBASE_PRIVATE_KEY=

# Optional notifications
# Example:
# FORM_NOTIFICATION_WEBHOOK_URL=https://hooks.example.com/nia-submissions
FORM_NOTIFICATION_WEBHOOK_URL=
# Example:
# FORM_NOTIFICATION_EMAIL_TO=niaptyltd@gmail.com
FORM_NOTIFICATION_EMAIL_TO=
# Use a verified Resend sender, for example:
# FORM_NOTIFICATION_FROM=Nia Events <website@yourdomain.com>
FORM_NOTIFICATION_FROM=
RESEND_API_KEY=
